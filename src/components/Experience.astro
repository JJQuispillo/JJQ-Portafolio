---
import SectionHeader from './SectionHeader.astro';
import { translations, type Lang } from '../data/translations';
import { getExperience } from '../lib/content';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = translations[lang];
const experiences = await getExperience(lang);
---

<section class="experience" id="experience" data-accent="experience">
  <div class="container">
    <SectionHeader variant="icon" label={t.experience.label} title={t.experience.title} />

    <div class="timeline" data-gsap="timeline">
      {experiences.map((exp, i) => (
        <article class="timeline-item" data-gsap="timeline-item">
          <div class="timeline-marker">
            <span class="marker-dot"></span>
            {i < experiences.length - 1 && <span class="marker-line"></span>}
          </div>
          
          <div class="timeline-content">
            <header class="exp-header">
              <span class="exp-period">{exp.period}</span>
              <span class="exp-location">{exp.location}</span>
            </header>
            
            <h3 class="exp-role">{exp.role}</h3>
            <h4 class="exp-company">{exp.company}</h4>
            
            <ul class="exp-list">
              {exp.highlights.map(h => (
                <li><span class="list-marker"></span>{h}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .experience { padding: var(--space-10) var(--space-6); background: var(--surface); position: relative; }
  .experience::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--gray-dark), transparent); }
  .container { max-width: var(--container-prose); margin: 0 auto; }
  .timeline { display: flex; flex-direction: column; gap: 0; }
  .timeline-item { display: grid; grid-template-columns: 40px 1fr; gap: var(--space-5); }
  .timeline-marker { display: flex; flex-direction: column; align-items: center; padding-top: var(--space-2); }
  .marker-dot { width: 12px; height: 12px; background: var(--accent-experience); border-radius: 50%; box-shadow: 0 0 15px var(--accent-experience); animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { box-shadow: 0 0 10px var(--accent-experience); } 50% { box-shadow: 0 0 25px var(--accent-experience), 0 0 40px var(--accent-experience); } }
  .marker-line { width: 2px; flex: 1; background: linear-gradient(to bottom, var(--accent-experience), transparent); margin-top: var(--space-4); opacity: 0.3; }
  .timeline-content { padding-bottom: var(--space-7); }
  .exp-header { display: flex; gap: var(--space-4); margin-bottom: var(--space-3); flex-wrap: wrap; }
  .exp-period { font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--magenta); letter-spacing: 0.05em; }
  .exp-location { font-size: var(--fs-sm); color: var(--gray); }
  .exp-role { font-family: var(--font-display); font-size: var(--fs-xl); font-weight: 600; color: var(--white); margin-bottom: var(--space-1); }
  .exp-company { font-family: var(--font-body); font-size: var(--fs-base); color: var(--accent-experience); margin-bottom: var(--space-5); }
  .exp-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .exp-list li { display: flex; gap: var(--space-3); font-size: 0.95rem; line-height: 1.6; color: var(--gray); }
  .list-marker { width: 6px; height: 6px; background: var(--gray-dark); border-radius: 50%; flex-shrink: 0; margin-top: var(--space-2); }
  @media (max-width: 600px) { .timeline-item { grid-template-columns: 24px 1fr; gap: var(--space-4); } .exp-role { font-size: var(--fs-lg); } }
</style>