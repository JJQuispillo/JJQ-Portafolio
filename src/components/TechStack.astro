---
import { translations, type Lang } from '../data/translations';
import { getTechnologies } from '../lib/content';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = translations[lang];

const technologies = await getTechnologies();

const categories = [...new Set(technologies.map(t => t.category))];
---

<section class="tech-stack" id="skills">
  <div class="container">
    <header class="section-header">
      <span class="section-label">{t.tech.label}</span>
      <h2 class="section-title">{t.tech.title}</h2>
    </header>

    <div class="stack-tabs">
      <button class="tab active" data-stack="all">ALL</button>
      {categories.map(cat => (
        <button class="tab" data-stack={cat}>{cat.toUpperCase()}</button>
      ))}
    </div>

    <div class="tech-grid">
      {technologies.map((tech, index) => (
        <article class="tech-card" data-stack={tech.category} style={`--i: ${index}`}>
          <div class="tech-icon">
            <img src={`/icons/${tech.icon}.svg`} alt={tech.name} />
          </div>
          <span class="tech-name">{tech.name}</span>
          <div class="tech-glow"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const stack = tab.getAttribute('data-stack');
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      document.querySelectorAll('.tech-card').forEach(card => {
        if (stack === 'all' || card.getAttribute('data-stack') === stack) {
          (card as HTMLElement).style.display = 'flex';
          setTimeout(() => (card as HTMLElement).style.opacity = '1', 50);
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .tech-stack { padding: 8rem 2rem; }
  .container { max-width: 1200px; margin: 0 auto; }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .section-label { display: block; font-family: var(--font-mono); font-size: 0.8rem; color: var(--magenta); letter-spacing: 0.3em; margin-bottom: 0.75rem; }
  .section-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700; letter-spacing: -0.02em; }
  .stack-tabs { display: flex; justify-content: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 3rem; }
  .tab { padding: 0.6rem 1.25rem; background: transparent; border: 1px solid var(--gray-dark); border-radius: 4px; font-family: var(--font-mono); font-size: 0.75rem; color: var(--gray); letter-spacing: 0.1em; cursor: pointer; transition: all 0.3s var(--transition); }
  .tab:hover { border-color: var(--gray); color: var(--white); }
  .tab.active { background: var(--cyan); border-color: var(--cyan); color: var(--dark); }
  .tech-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 1rem; }
  .tech-card { position: relative; background: var(--surface); border: 1px solid var(--gray-dark); border-radius: 8px; padding: 1.5rem 1rem; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; cursor: pointer; transition: all 0.4s var(--transition-slow); animation: cardIn 0.6s var(--transition-slow) forwards; animation-delay: calc(var(--i) * 0.05s); opacity: 0; }
  @keyframes cardIn { from { opacity: 0; transform: translateY(20px) scale(0.95); } to { opacity: 1; transform: translateY(0) scale(1); } }
  .tech-glow { position: absolute; inset: 0; border-radius: 8px; background: radial-gradient(circle at center, var(--cyan), transparent 70%); opacity: 0; transition: opacity 0.4s var(--transition); pointer-events: none; }
  .tech-card:hover { transform: translateY(-6px); border-color: var(--cyan); box-shadow: 0 12px 40px rgba(0, 255, 245, 0.12); }
  .tech-card:hover .tech-glow { opacity: 0.08; }
  .tech-icon { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; transition: transform 0.3s var(--transition); }
  .tech-icon img { width: 100%; height: 100%; object-fit: contain; }
  .tech-card:hover .tech-icon { transform: scale(1.1); }
  .tech-name { font-family: var(--font-body); font-size: 0.85rem; font-weight: 500; color: var(--white); letter-spacing: 0.02em; }
  @media (max-width: 768px) { .tech-grid { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); } .tech-card { padding: 1.25rem 0.75rem; } .tech-icon { width: 36px; height: 36px; } }
</style>