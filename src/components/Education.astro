---
import SectionHeader from './SectionHeader.astro';
import { translations, type Lang } from '../data/translations';
import { getEducation, getLanguages } from '../lib/content';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = translations[lang];
const edu = await getEducation(lang);
const languages = await getLanguages();
---

<section class="education" id="education" data-accent="education">
  <div class="container">
    <SectionHeader variant="bordered" label={t.education.label} title={t.education.title} />

    <div class="edu-grid">
      <article class="edu-card">
        <div class="edu-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/>
            <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>
          </svg>
        </div>
        <h3 class="edu-degree">{edu?.degree || 'Ingeniería de Sistemas Inteligentes'}</h3>
        <h4 class="edu-institution">{edu?.institution || 'Universidad Ecotec'}</h4>
        <span class="edu-year">{edu?.year || '2027 (Estimado)'}</span>
      </article>

      <article class="lang-card">
        <div class="lang-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20"/>
            <path d="M12 2c3.5 3.5 9 3.5 12.5 0S18.5 19 12 22 5.5 18.5 2 12 5.5 5.5 12 2z"/>
          </svg>
          <span>{t.education.languages}</span>
        </div>
        <div class="lang-list">
          {(languages.length > 0 ? languages : [
            { name: "Español", level: "Nativo" },
            { name: "Inglés", level: "B1+", note: "3 meses USA" }
          ]).map(lang => (
            <div class="lang-item">
              <span class="lang-name">{lang.name}</span>
              <span class="lang-level">{lang.level}</span>
              {lang.note && <span class="lang-note">{lang.note}</span>}
            </div>
          ))}
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .education { padding: var(--space-10) var(--space-6); background: var(--surface); }
  .container { max-width: var(--container-prose); margin: 0 auto; }
  .edu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-5); }
  .edu-card, .lang-card { background: var(--surface-light); border: 1px solid var(--gray-dark); border-radius: var(--radius-md); padding: var(--space-6); transition: all 0.3s var(--transition); }
  .edu-card:hover, .lang-card:hover { border-color: var(--accent-education); box-shadow: 0 8px 30px rgba(0, 255, 245, 0.08); transform: translateY(-4px); }
  .edu-icon { width: 50px; height: 50px; color: var(--accent-education); margin-bottom: var(--space-5); }
  .edu-icon svg { width: 100%; height: 100%; }
  .edu-degree { font-family: var(--font-display); font-size: var(--fs-lg); font-weight: 600; color: var(--white); margin-bottom: var(--space-2); }
  .edu-institution { font-family: var(--font-body); font-size: var(--fs-base); color: var(--accent-education); margin-bottom: var(--space-3); }
  .edu-year { font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--gray); }
  .lang-card { display: flex; flex-direction: column; gap: var(--space-5); }
  .lang-header { display: flex; align-items: center; gap: var(--space-3); color: var(--magenta); }
  .lang-header svg { width: 28px; height: 28px; }
  .lang-header span { font-family: var(--font-display); font-size: var(--fs-sm); font-weight: 600; letter-spacing: 0.1em; }
  .lang-list { display: flex; flex-direction: column; gap: var(--space-4); }
  .lang-item { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-4); background: rgba(255, 255, 255, 0.02); border-left: 2px solid var(--magenta); transition: all 0.3s var(--transition); }
  .lang-item:hover { background: rgba(255, 0, 170, 0.05); border-left-color: var(--accent-education); }
  .lang-name { font-family: var(--font-display); font-size: var(--fs-base); font-weight: 500; color: var(--white); }
  .lang-level { font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--magenta); }
  .lang-note { font-size: var(--fs-sm); color: var(--gray); margin-left: auto; }
</style>