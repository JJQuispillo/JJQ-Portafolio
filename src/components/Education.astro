---
import { translations, type Lang } from '../data/translations';
import { getEducation, getLanguages } from '../lib/content';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = translations[lang];
const edu = await getEducation(lang);
const languages = await getLanguages();
---

<section class="education" id="education">
  <div class="container">
    <header class="section-header">
      <span class="section-label">{t.education.label}</span>
      <h2 class="section-title">{t.education.title}</h2>
    </header>

    <div class="edu-grid">
      <article class="edu-card">
        <div class="edu-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/>
            <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>
          </svg>
        </div>
        <h3 class="edu-degree">{edu?.degree || 'Ingeniería de Sistemas Inteligentes'}</h3>
        <h4 class="edu-institution">{edu?.institution || 'Universidad Ecotec'}</h4>
        <span class="edu-year">{edu?.year || '2027 (Estimado)'}</span>
      </article>

      <article class="lang-card">
        <div class="lang-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20"/>
            <path d="M12 2c3.5 3.5 9 3.5 12.5 0S18.5 19 12 22 5.5 18.5 2 12 5.5 5.5 12 2z"/>
          </svg>
          <span>{t.education.languages}</span>
        </div>
        <div class="lang-list">
          {(languages.length > 0 ? languages : [
            { name: "Español", level: "Nativo" },
            { name: "Inglés", level: "B1+", note: "3 meses USA" }
          ]).map(lang => (
            <div class="lang-item">
              <span class="lang-name">{lang.name}</span>
              <span class="lang-level">{lang.level}</span>
              {lang.note && <span class="lang-note">{lang.note}</span>}
            </div>
          ))}
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .education { padding: 8rem 2rem; background: var(--surface); }
  .container { max-width: 900px; margin: 0 auto; }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .section-label { display: block; font-family: var(--font-mono); font-size: 0.8rem; color: var(--magenta); letter-spacing: 0.3em; margin-bottom: 0.75rem; }
  .section-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700; letter-spacing: -0.02em; }
  .edu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .edu-card, .lang-card { background: var(--surface-light); border: 1px solid var(--gray-dark); padding: 2rem; transition: all 0.3s var(--transition); }
  .edu-card:hover, .lang-card:hover { border-color: var(--cyan); box-shadow: 0 8px 30px rgba(0, 255, 245, 0.08); }
  .edu-icon { width: 50px; height: 50px; color: var(--cyan); margin-bottom: 1.5rem; }
  .edu-icon svg { width: 100%; height: 100%; }
  .edu-degree { font-family: var(--font-display); font-size: 1.2rem; font-weight: 600; color: var(--white); margin-bottom: 0.5rem; }
  .edu-institution { font-family: var(--font-body); font-size: 1rem; color: var(--cyan); margin-bottom: 0.75rem; }
  .edu-year { font-family: var(--font-mono); font-size: 0.8rem; color: var(--gray); }
  .lang-card { display: flex; flex-direction: column; gap: 1.5rem; }
  .lang-header { display: flex; align-items: center; gap: 0.75rem; color: var(--magenta); }
  .lang-header svg { width: 28px; height: 28px; }
  .lang-header span { font-family: var(--font-display); font-size: 0.9rem; font-weight: 600; letter-spacing: 0.1em; }
  .lang-list { display: flex; flex-direction: column; gap: 1rem; }
  .lang-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: rgba(255, 255, 255, 0.02); border-left: 2px solid var(--magenta); }
  .lang-name { font-family: var(--font-display); font-size: 1rem; font-weight: 500; color: var(--white); }
  .lang-level { font-family: var(--font-mono); font-size: 0.8rem; color: var(--magenta); }
  .lang-note { font-size: 0.75rem; color: var(--gray); margin-left: auto; }
</style>