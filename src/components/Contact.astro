---
import SectionHeader from './SectionHeader.astro';
import { translations, type Lang } from '../data/translations';
import { getProfile } from '../lib/content';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = translations[lang];

const profile = await getProfile() || { email: "jjquispillo@gmail.com", github: "JJQUISPILLO", linkedin: "johnjairoquispillodev" };

const links = [
  { name: "GitHub", url: `https://github.com/${profile.github}`, key: "GitHub" },
  { name: "LinkedIn", url: `https://linkedin.com/in/${profile.linkedin}`, key: "LinkedIn" },
  { name: "Email", url: `mailto:${profile.email}`, key: "Email" },
];
---

<section class="contact" id="contact" data-accent="contact">
  <div class="container">
    <SectionHeader variant="minimal" label={t.contact.label} title={t.contact.title} />

    <div class="contact-content">
      <p class="contact-intro">
        {t.contact.intro}
      </p>

      <a href={`mailto:${profile.email}`} class="contact-email">
        <span class="email-label">{t.contact.sayHello}</span>
        <span class="email-address">{profile.email}</span>
        <svg class="email-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
        </svg>
      </a>

      <div class="contact-links">
        {links.map(link => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="contact-link">
            <span class="link-name">{link.name}</span>
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
            </svg>
          </a>
        ))}
      </div>
    </div>

    <footer class="footer">
      <div class="footer-content">
        <div class="footer-brand">
          <span class="brand-bracket">&lt;</span>JJQ<span class="brand-bracket">/&gt;</span>
        </div>
        <p class="footer-copy">{t.contact.footer}</p>
        <div class="footer-tech">
          <span>{t.contact.astropy}</span>
          <span class="dot"></span>
          <span>2024</span>
        </div>
      </div>
    </footer>
  </div>
</section>

<style>
  .contact {
    padding: var(--space-10) var(--space-6) var(--space-8);
    position: relative;
  }

  .container {
    max-width: var(--container-narrow);
    margin: 0 auto;
  }

  .contact-content {
    text-align: center;
  }

  .contact-intro {
    font-size: var(--fs-md);
    line-height: 1.7;
    color: var(--gray);
    margin-bottom: var(--space-7);
  }

  .contact-email {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-7);
    background: var(--surface);
    border: 1px solid var(--gray-dark);
    text-decoration: none;
    transition: all 0.4s var(--transition);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-6);
  }

  .contact-email:hover {
    border-color: var(--accent-contact);
    box-shadow: 0 10px 40px rgba(139, 0, 255, 0.15);
    transform: translateY(-4px);
  }

  .email-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--gray);
    letter-spacing: 0.2em;
  }

  .email-address {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    color: var(--white);
  }

  .email-icon {
    width: 24px;
    height: 24px;
    color: var(--accent-contact);
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: all 0.3s ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact-email:hover .email-icon {
      opacity: 1;
      transform: translate(4px, -4px);
    }
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    background: var(--surface);
    border: 1px solid var(--gray-dark);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.3s var(--transition);
  }

  .contact-link:hover {
    border-color: var(--accent-contact);
    color: var(--accent-contact);
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(139, 0, 255, 0.15);
  }

  .link-name {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--white);
  }

  .link-arrow {
    width: 16px;
    height: 16px;
    opacity: 0;
    transform: translate(-4px, 0);
    transition: all 0.3s ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact-link:hover .link-arrow {
      opacity: 1;
      transform: translate(4px, 0);
    }
  }

  .footer {
    margin-top: var(--space-9);
    padding-top: var(--space-6);
    border-top: 1px solid var(--gray-dark);
  }

  .footer-content {
    text-align: center;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--white);
    margin-bottom: var(--space-3);
  }

  .brand-bracket {
    color: var(--magenta);
  }

  .footer-copy {
    font-size: var(--fs-sm);
    color: var(--gray);
    margin-bottom: var(--space-2);
  }

  .footer-tech {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--gray);
  }

  .dot {
    width: 4px;
    height: 4px;
    background: var(--accent-contact);
    border-radius: 50%;
  }

  @media (max-width: 600px) {
    .contact-email {
      width: 100%;
      padding: var(--space-5);
    }

    .contact-links {
      flex-direction: column;
      align-items: center;
    }

    .contact-link {
      width: 100%;
      max-width: 200px;
      justify-content: center;
    }
  }
</style>