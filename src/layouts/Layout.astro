---
const { lang: langProp } = Astro.props as { lang?: string };
const currentLang = langProp === "en" ? "en" : "es";
const altLang = currentLang === "es" ? "en" : "es";
const path = Astro.url.pathname;
const esHref = currentLang === "es" ? path : path.replace(/^\/en\//, "/es/");
const enHref = currentLang === "en" ? path : path.replace(/^\/es\//, "/en/");
const canonical = path;
---
<!doctype html>
<html lang={currentLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="John Jairo Quispillo - Full Stack Developer Portfolio" />
		<meta name="theme-color" content="#050508" />
		<meta property="og:title" content="John Jairo Quispillo | Full Stack Developer" />
		<meta property="og:description" content="Full Stack Developer & DevOps Engineer. Building with React, Flutter, .NET, and modern cloud infrastructure." />
		<meta property="og:image" content="/profile.jpg" />
		<meta property="og:type" content="website" />
	<meta name="twitter:card" content="summary_large_image" />
<link rel="preload" as="font" type="font/woff2" href="/fonts/syne-latin.woff2" crossorigin>
<link rel="preload" as="image" href="/background-poster.jpg" fetchpriority="high">
	<link rel="canonical" href={canonical} />
	<link rel="alternate" hreflang="es" href={esHref} />
	<link rel="alternate" hreflang="en" href={enHref} />
	<link rel="alternate" hreflang="x-default" href="/es/" />
	<title>John Jairo Quispillo | Full Stack Developer</title>
	</head>
	<body>
		<div id="loader" class="loader" aria-hidden="true">
			<div class="loader-content">
				<div class="loader-logo">
					<span class="loader-bracket">&lt;</span>JJQ<span class="loader-bracket">/&gt;</span>
				</div>
				<div class="loader-bar-track">
					<div class="loader-bar"></div>
				</div>
			</div>
		</div>

		<div class="noise-overlay"></div>
		<div id="video-bg" class="video-bg" aria-hidden="true">
		<video autoplay muted loop playsinline poster="/background-poster.jpg" preload="none"></video>
			<div class="video-color-field"></div>
			<div class="video-depth-grid"></div>
			<div class="video-energy-orb"></div>
			<div class="video-light-beam"></div>
			<div class="video-scanlines"></div>
			<div class="video-vignette"></div>
		</div>

		<div class="main-content">
			<slot />
		</div>

		<div id="cursor-follower" class="cursor-follower"></div>
		<div id="cursor-dots" class="cursor-dots" aria-hidden="true">
			<div class="cursor-dot" data-i="0"></div>
			<div class="cursor-dot" data-i="1"></div>
			<div class="cursor-dot" data-i="2"></div>
			<div class="cursor-dot" data-i="3"></div>
		</div>
	</body>
</html>

<script>
	const loader = document.getElementById('loader');
	const video = document.querySelector('#video-bg video');
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	let loaderHidden = false;
	function hideLoader() {
		if (loaderHidden) return;
		loaderHidden = true;
		loader?.classList.add('hidden');
		document.body.classList.add('loaded');
	}

	if (prefersReducedMotion) {
		hideLoader();
	} else {
		const ric = window.requestIdleCallback || ((cb) => setTimeout(cb, 0));
		const schedule = () => ric(hideLoader, { timeout: 300 });
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', schedule);
		} else {
			schedule();
		}
		setTimeout(hideLoader, 300);
	}

	function loadVideo() {
		if (!video || prefersReducedMotion) return;
		if (navigator.connection && navigator.connection.saveData) return;
		const webm = document.createElement('source');
		webm.src = '/background-video.webm';
		webm.type = 'video/webm';
		const mp4 = document.createElement('source');
		mp4.src = '/background-video.mp4';
		mp4.type = 'video/mp4';
		video.append(webm, mp4);
		video.load();
	}
	const videoRic = window.requestIdleCallback || ((cb) => setTimeout(cb, 0));
	videoRic(loadVideo, { timeout: 2000 });
</script>

<script>
	async function initGSAP() {
		const ENABLED = window.matchMedia(
			'(hover: hover) and (min-width: 768px) and (prefers-reduced-motion: no-preference)'
		).matches;
		if (!ENABLED) return;

		try {
			const { gsap } = await import('gsap');
			const { ScrollTrigger } = await import('gsap/ScrollTrigger');
			gsap.registerPlugin(ScrollTrigger);

			gsap.matchMedia().add(
				'(hover: hover) and (min-width: 768px)',
				() => {
				gsap.from('[data-gsap="timeline"] .marker-line', {
					scaleY: 0, transformOrigin: 'top center',
					scrollTrigger: {
						trigger: '[data-gsap="timeline"]',
						start: 'top 80%', end: 'bottom 60%',
						scrub: 1
					}
				});

				gsap.utils.toArray('[data-gsap="timeline-item"]').forEach(function(el, i) {
					var x = i % 2 === 0 ? -60 : 60;
					gsap.from(el, {
						x: x, opacity: 0, duration: 0.8,
						ease: 'power3.out',
						scrollTrigger: {
							trigger: el,
							start: 'top 85%', end: 'top 50%',
							scrub: 1
						}
					});
				});

				gsap.to('[data-gsap="parallax"]', {
						yPercent: (i, el) => Number(el.dataset.parallaxSpeed || 20),
						ease: 'none',
						scrollTrigger: {
							trigger: '#hero',
							start: 'top top', end: 'bottom top',
							scrub: true
						}
					});

					document.querySelectorAll('[data-gsap="fade-up"]').forEach(section => {
						gsap.from(section, {
							y: 40, opacity: 0, duration: 0.8,
							ease: 'power3.out',
							scrollTrigger: {
								trigger: section,
								start: 'top 85%',
								end: 'top 60%',
								scrub: 1
							}
						});
					});

					return () => { ScrollTrigger.getAll().forEach(t => t.kill()); };
				}
			);

			window.gsap = gsap;
		} catch (e) {
			console.warn('GSAP init skipped:', e);
		}
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initGSAP);
	} else {
		initGSAP();
	}
</script>

<script>
	(function() {
		var MM = window.matchMedia('(hover: hover) and (min-width: 768px) and (prefers-reduced-motion: no-preference)');
		if (!MM.matches) return;

		var follower = document.getElementById('cursor-follower');
		var dots = document.querySelectorAll('.cursor-dot');
		if (!follower && !dots.length) return;

		var target = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
		var followerPos = { x: target.x, y: target.y };
		var dotPositions = Array.from({ length: dots.length }, () => ({ x: target.x, y: target.y }));
		var running = document.visibilityState === 'visible';

		document.addEventListener('mousemove', function(e) {
			target.x = e.clientX;
			target.y = e.clientY;
		});

		document.addEventListener('visibilitychange', function() {
			var wasRunning = running;
			running = document.visibilityState === 'visible';
			if (running && !wasRunning) tick();
		});

		if (follower) {
			document.querySelectorAll('a, button, .tech-card, .project-card, .social-link, .cta-primary, .cta-secondary, .contact-email, .contact-link, .tab').forEach(function(el) {
				el.addEventListener('mouseenter', function() { follower.classList.add('hover'); });
				el.addEventListener('mouseleave', function() { follower.classList.remove('hover'); });
			});
		}

		function tick() {
			if (!running) return;
			if (follower) {
				followerPos.x += (target.x - followerPos.x) * 0.12;
				followerPos.y += (target.y - followerPos.y) * 0.12;
				follower.style.transform = 'translate(' + (followerPos.x - 10) + 'px, ' + (followerPos.y - 10) + 'px)';
			}
			var prev = target;
			dots.forEach(function(dot, i) {
				dotPositions[i].x += (prev.x - dotPositions[i].x) * 0.15;
				dotPositions[i].y += (prev.y - dotPositions[i].y) * 0.15;
				dot.style.transform = 'translate(' + (dotPositions[i].x - 4) + 'px, ' + (dotPositions[i].y - 4) + 'px)';
				prev = dotPositions[i];
			});
			requestAnimationFrame(tick);
		}
		tick();
	})();
</script>

<script>
	(function() {
		var TILT_MM = window.matchMedia('(hover: hover) and (min-width: 768px) and (prefers-reduced-motion: no-preference)');
		if (!TILT_MM.matches) return;

		var cards = document.querySelectorAll('[data-gsap="tilt"]');
		cards.forEach(function(card) {
			card.addEventListener('mousemove', function(e) {
				var rect = card.getBoundingClientRect();
				var x = e.clientX - rect.left;
				var y = e.clientY - rect.top;
				var centerX = rect.width / 2;
				var centerY = rect.height / 2;
				var rotateX = (y - centerY) / centerY * -15;
				var rotateY = (x - centerX) / centerX * 15;
				card.style.transform = 'perspective(800px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg) scale3d(1.02,1.02,1.02)';

				var glow = card.querySelector('.card-glow');
				if (glow) {
					var dx = (x - centerX) / centerX;
					var dy = (y - centerY) / centerY;
					glow.style.transform = 'translate(' + (dx * 10) + 'px, ' + (dy * 10) + 'px)';
				}
			});

			card.addEventListener('mouseleave', function() {
				card.style.transform = 'perspective(800px) rotateX(0) rotateY(0) scale3d(1,1,1)';
				var glow = card.querySelector('.card-glow');
				if (glow) glow.style.transform = 'translate(0, 0)';
			});
		});
	})();
</script>

<style is:global>
	@font-face {
		font-family: 'Syne';
		font-style: normal;
		font-weight: 500 800;
		font-display: swap;
		src: url('/fonts/syne-latin-ext.woff2') format('woff2');
		unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
	}
	@font-face {
		font-family: 'Syne';
		font-style: normal;
		font-weight: 500 800;
		font-display: swap;
		src: url('/fonts/syne-latin.woff2') format('woff2');
		unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
	}
	@font-face {
		font-family: 'Space Grotesk';
		font-style: normal;
		font-weight: 300 700;
		font-display: swap;
		src: url('/fonts/space-grotesk-latin-ext.woff2') format('woff2');
		unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
	}
	@font-face {
		font-family: 'Space Grotesk';
		font-style: normal;
		font-weight: 300 700;
		font-display: swap;
		src: url('/fonts/space-grotesk-latin.woff2') format('woff2');
		unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
	}
	@font-face {
		font-family: 'JetBrains Mono';
		font-style: normal;
		font-weight: 100 800;
		font-display: swap;
		src: url('/fonts/jetbrains-mono-latin-ext.woff2') format('woff2');
		unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
	}
	@font-face {
		font-family: 'JetBrains Mono';
		font-style: normal;
		font-weight: 100 800;
		font-display: swap;
		src: url('/fonts/jetbrains-mono-latin.woff2') format('woff2');
		unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
	}

	:root {
		--cyan: #00fff5;
		--magenta: #ff00aa;
		--purple: #8b00ff;
		--dark: #050508;
		--dark-alt: #0a0a0f;
		--surface: #111118;
		--surface-light: #1a1a24;
		--white: #f0f0f5;
		--gray: #8b8ba0;
		--gray-muted: #6b6b80;
		--gray-dark: #2a2a35;

		--font-display: 'Syne', sans-serif;
		--font-body: 'Space Grotesk', sans-serif;
		--font-mono: 'JetBrains Mono', monospace;

		--transition: cubic-bezier(0.23, 1, 0.32, 1);
		--transition-slow: cubic-bezier(0.16, 1, 0.3, 1);

		--fs-xs: 0.75rem;
		--fs-sm: 0.875rem;
		--fs-base: 1rem;
		--fs-md: 1.125rem;
		--fs-lg: 1.25rem;
		--fs-xl: 1.5rem;
		--fs-2xl: 2rem;
		--fs-3xl: clamp(2rem, 5vw, 3.5rem);
		--fs-4xl: clamp(2.5rem, 6vw, 4.5rem);
		--fs-5xl: clamp(3rem, 8vw, 6rem);

		--space-1: 0.25rem;
		--space-2: 0.5rem;
		--space-3: 0.75rem;
		--space-4: 1rem;
		--space-5: 1.5rem;
		--space-6: 2rem;
		--space-7: 3rem;
		--space-8: 4rem;
		--space-9: 6rem;
		--space-10: 8rem;
		--space-11: 10rem;

		--radius-xs: 2px;
		--radius-sm: 4px;
		--radius-md: 8px;
		--radius-lg: 12px;
		--radius-pill: 9999px;

		--accent-hero: var(--cyan);
		--accent-skills: var(--magenta);
		--accent-experience: var(--purple);
		--accent-projects: var(--magenta);
		--accent-education: var(--cyan);
		--accent-contact: var(--purple);

		--container-narrow: 700px;
		--container-prose: 900px;
		--container-wide: 1200px;
		--container-hero: 1400px;

		--accent: var(--cyan);
	}

	[data-accent="hero"] { --accent: var(--accent-hero); }
	[data-accent="skills"] { --accent: var(--accent-skills); }
	[data-accent="experience"] { --accent: var(--accent-experience); }
	[data-accent="projects"] { --accent: var(--accent-projects); }
	[data-accent="education"] { --accent: var(--accent-education); }
	[data-accent="contact"] { --accent: var(--accent-contact); }

	* { margin: 0; padding: 0; box-sizing: border-box; }
	html { scroll-behavior: smooth; }

	body {
		font-family: var(--font-body);
		background: var(--dark);
		color: var(--white);
		min-height: 100vh;
		overflow-x: hidden;
		cursor: crosshair;
	}

	:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
		border-radius: var(--radius-xs);
	}

	:focus:not(:focus-visible) {
		outline: none;
	}

	@media (prefers-reduced-motion: reduce) {
		:focus-visible {
			outline-offset: 2px;
		}
	}

	.loader {
		position: fixed;
		inset: 0;
		z-index: 10000;
		background: var(--dark);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: opacity 0.8s ease, visibility 0.8s ease;
	}

	.loader.hidden {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	.loader-content { text-align: center; }

	.loader-logo {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 6vw, 4rem);
		font-weight: 800;
		color: var(--white);
		letter-spacing: 0.05em;
		margin-bottom: 2rem;
	}

	.loader-bracket { color: var(--magenta); }

	.loader-bar-track {
		width: 200px;
		height: 2px;
		background: var(--gray-dark);
		overflow: hidden;
		margin: 0 auto;
	}

	.loader-bar {
		height: 100%;
		width: 40%;
		background: linear-gradient(90deg, var(--cyan), var(--magenta));
		animation: loadBar 1.5s ease-in-out infinite;
	}

	@keyframes loadBar {
		0% { transform: translateX(-100%); }
		100% { transform: translateX(350%); }
	}

	.main-content {
		opacity: 1;
	}

	.noise-overlay {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 9999;
		opacity: 0.035;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
	}

	.video-bg {
		position: fixed;
		inset: 0;
		z-index: -1;
		overflow: hidden;
		background:
			radial-gradient(circle at 72% 18%, rgba(0, 255, 245, 0.16), transparent 30%),
			radial-gradient(circle at 22% 72%, rgba(255, 0, 170, 0.12), transparent 32%),
			var(--dark);
	}

	.video-bg video {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.62;
		filter: saturate(1.28) contrast(1.12) brightness(0.92);
		transform: scale(1.03);
	}

	.video-bg > div {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.video-color-field {
		background:
			radial-gradient(ellipse 58% 42% at 68% 16%, rgba(0, 255, 245, 0.18), transparent 62%),
			radial-gradient(ellipse 42% 55% at 18% 76%, rgba(255, 0, 170, 0.14), transparent 60%),
			linear-gradient(115deg, rgba(5, 5, 8, 0.3), rgba(139, 0, 255, 0.08) 48%, rgba(5, 5, 8, 0.56));
		mix-blend-mode: screen;
		opacity: 0.9;
	}

	.video-depth-grid {
		will-change: transform, opacity;
		inset: auto -12% -18%;
		height: 62vh;
		background-image:
			linear-gradient(rgba(0, 255, 245, 0.22) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 0, 170, 0.16) 1px, transparent 1px);
		background-size: 82px 82px;
		mask-image: linear-gradient(to top, black 0%, rgba(0, 0, 0, 0.75) 45%, transparent 100%);
		opacity: 0.34;
		transform: perspective(620px) rotateX(62deg) translateY(4vh);
		transform-origin: bottom center;
		animation: gridDrift 16s linear infinite;
	}

	.video-energy-orb {
		will-change: transform, opacity;
		inset: auto auto 8vh 7vw;
		width: min(46vw, 560px);
		height: min(46vw, 560px);
		border-radius: 50%;
		background:
			radial-gradient(circle, rgba(0, 255, 245, 0.22) 0%, rgba(0, 255, 245, 0.08) 28%, transparent 66%),
			conic-gradient(from 210deg, transparent, rgba(0, 255, 245, 0.22), rgba(255, 0, 170, 0.18), transparent 72%);
		filter: blur(18px);
		opacity: 0.52;
		mix-blend-mode: screen;
		animation: orbBreath 9s var(--transition-slow) infinite alternate;
	}

	.video-light-beam {
		will-change: transform, opacity;
		inset: -24% auto auto 48%;
		width: 34vw;
		height: 150vh;
		background: linear-gradient(90deg, transparent, rgba(0, 255, 245, 0.1), rgba(255, 0, 170, 0.08), transparent);
		filter: blur(22px);
		opacity: 0.58;
		mix-blend-mode: screen;
		transform: rotate(24deg);
		animation: beamSweep 13s ease-in-out infinite alternate;
	}

	.video-scanlines {
		will-change: transform, opacity;
		background:
			linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, transparent 0%, rgba(0, 255, 245, 0.05) 50%, transparent 100%);
		background-size: 100% 5px, 180% 100%;
		opacity: 0.22;
		animation: scanlineDrift 8s linear infinite;
	}

	.video-vignette {
		background:
			radial-gradient(ellipse at center, transparent 28%, rgba(5, 5, 8, 0.34) 64%, rgba(5, 5, 8, 0.82) 100%),
			linear-gradient(180deg, rgba(5, 5, 8, 0.52), transparent 24%, transparent 72%, rgba(5, 5, 8, 0.72));
	}

	@keyframes gridDrift {
		0% { background-position: 0 0, 0 0; }
		100% { background-position: 0 82px, 82px 0; }
	}

	@keyframes orbBreath {
		0% { transform: scale(0.92) translate3d(-2vw, 2vh, 0); opacity: 0.36; }
		100% { transform: scale(1.08) translate3d(2vw, -2vh, 0); opacity: 0.58; }
