---
import HomePage from "../../components/HomePage.astro";
import type { Lang } from "../../lib/content";

export async function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
---

<HomePage lang={lang} />
