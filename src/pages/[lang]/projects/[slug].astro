---
import Layout from "../../../layouts/Layout.astro";
import { getProjects, type Lang } from "../../../lib/content";
import { translations } from "../../../data/translations";

export async function getStaticPaths() {
  const langs: Lang[] = ["es", "en"];
  const paths: { params: { lang: Lang; slug: string }; props: { lang: Lang; index: number } }[] = [];

  for (const lang of langs) {
    const projects = await getProjects(lang);
    for (const [index, p] of projects.entries()) {
      paths.push({ params: { lang, slug: p.slug }, props: { lang, index } });
    }
  }

  return paths;
}

const { lang, index } = Astro.props as { lang: Lang; index: number };
const { slug } = Astro.params;
const t = translations[lang];

const projects = await getProjects(lang);
const projectIndex = projects.findIndex(p => p.slug === slug);
const project = projectIndex !== -1 ? projects[projectIndex] : null;

if (!project) {
  return Astro.redirect(`/${lang}/`);
}

const accent = project.color || "#00fff5";
const homeHref = `/${lang}/`;
const backHref = `/${lang}/#projects`;
---

<Layout lang={lang}>
  <nav class="navbar" id="navbar">
    <a href={homeHref} class="nav-logo">
      <span class="logo-bracket">&lt;</span>JJQ<span class="logo-bracket">/&gt;</span>
    </a>
    <a href={backHref} class="back-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
        <line x1="17" y1="7" x2="7" y2="17"/>
        <polyline points="17 17 7 17 7 7"/>
      </svg>
      <span>{lang === "es" ? "Volver" : "Back"}</span>
    </a>
  </nav>

  <main class="project-detail" style={`--accent: ${accent}`}>
    <div class="container">
      <header class="detail-header">
        <div class="detail-number">{String(projectIndex + 1).padStart(2, '0')}</div>
        <h1 class="detail-title">{project.name}</h1>
        <p class="detail-desc">{project.description}</p>

        <div class="detail-tags">
          {project.tech.map(tag => <span class="tag">{tag}</span>)}
        </div>

        <div class="detail-links">
          {project.repoUrl && (
            <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-repo">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              {lang === "es" ? "Ver repositorio" : "View repository"}
            </a>
          )}
        </div>
      </header>

      <div class="detail-body">
        <section class="detail-section" data-gsap="fade-up">
          <h2 class="section-subtitle">
            {lang === "es" ? "Acerca del proyecto" : "About the project"}
          </h2>
          {project.details ? (
            <p class="detail-text">{project.details}</p>
          ) : (
            <p class="detail-text placeholder">
              {lang === "es"
                ? "Contenido en preparación. Pronto encontrarás aquí una descripción detallada, capturas de pantalla y más información sobre este proyecto."
                : "Content coming soon. You'll soon find a detailed description, screenshots, and more information about this project."}
            </p>
          )}
        </section>

        {project.screenshots.length > 0 && (
          <section class="detail-section" data-gsap="fade-up" data-delay="0.05">
            <h2 class="section-subtitle">
              {lang === "es" ? "Capturas de pantalla" : "Screenshots"}
            </h2>
            <div class="screenshots-grid">
              {project.screenshots.map(src => (
                <img src={src} alt={`${project.name} screenshot`} class="screenshot" loading="lazy" width="800" height="450" />
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </main>
</Layout>

<script>
  const navLinks = document.querySelectorAll(".nav-link");
  // Scroll reveal animations
  const sections = document.querySelectorAll(".detail-section");
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  sections.forEach((s) => revealObserver.observe(s));
</script>

<style>
  .navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.5rem 3rem;
    background: rgba(5, 5, 8, 0.9); backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }
  .nav-logo {
    font-family: var(--font-display); font-size: 1.5rem; font-weight: 700;
    color: var(--white); text-decoration: none; letter-spacing: 0.05em;
  }
  .nav-logo:hover { color: var(--cyan); text-shadow: 0 0 20px var(--cyan); }
  .logo-bracket { color: var(--magenta); }
  .back-link {
    display: flex; align-items: center; gap: 0.5rem;
    color: var(--gray); text-decoration: none; font-size: 0.9rem;
    transition: color 0.3s ease;
  }
  .back-link:hover { color: var(--accent); }

  .project-detail { padding: 8rem 2rem 4rem; }
  .container { max-width: 900px; margin: 0 auto; }

  .detail-header { margin-bottom: 4rem; }
  .detail-number {
    font-family: var(--font-display); font-size: 4rem; font-weight: 800;
    color: var(--accent); opacity: 0.1; line-height: 1; margin-bottom: 1rem;
  }
  .detail-title {
    font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700; color: var(--white); margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .detail-desc {
    font-size: 1.1rem; line-height: 1.7; color: var(--gray);
    margin-bottom: 1.5rem; max-width: 700px;
  }
  .detail-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .tag {
    padding: 0.4rem 0.8rem; background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--gray-dark); border-radius: 3px;
    font-family: var(--font-mono); font-size: 0.75rem; color: var(--gray);
    transition: all 0.3s ease;
  }
  .tag:hover { border-color: var(--accent); color: var(--accent); }

  .detail-links { display: flex; gap: 1rem; }
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.5rem; border-radius: 4px;
    font-size: 0.9rem; text-decoration: none; transition: all 0.3s ease;
  }
  .btn-repo {
    background: rgba(255, 255, 255, 0.05); border: 1px solid var(--gray-dark);
    color: var(--white);
  }
  .btn-repo:hover {
    border-color: var(--cyan); background: rgba(0, 255, 245, 0.05);
    transform: translateY(-2px);
  }

  .detail-body { border-top: 1px solid var(--gray-dark); padding-top: 3rem; }
  .detail-section { margin-bottom: 3rem; opacity: 0; transform: translateY(20px); transition: opacity 0.6s var(--transition-slow), transform 0.6s var(--transition-slow); }
  .detail-section.visible { opacity: 1; transform: translateY(0); }
  .section-subtitle {
    font-family: var(--font-display); font-size: 1.3rem; font-weight: 600;
    color: var(--white); margin-bottom: 1rem;
  }
  .detail-text {
    font-size: 1rem; line-height: 1.8; color: var(--gray);
  }
  .detail-text.placeholder {
    color: var(--gray-dark); font-style: italic;
  }

  .screenshots-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .screenshot {
    width: 100%; border-radius: 8px; border: 1px solid var(--gray-dark);
  }

  @media (max-width: 768px) {
    .navbar { padding: 1rem 1.5rem; }
    .project-detail { padding: 6rem 1.5rem 3rem; }
  }
</style>
